# ─────────────────────────────────────────────────────────────────────────────
# Activity image sources for `npm run fetch-images`
# Copy this file to .env.local and fill in your keys.
# All sources are optional — Wikipedia works without any key.
# ─────────────────────────────────────────────────────────────────────────────

# Unsplash — best quality photos, free, https://unsplash.com/developers
# Sign up → New Application → copy "Access Key"
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels — excellent variety, free, https://www.pexels.com/api/
# Sign up → My Profile → API → copy key
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay — huge library, free, https://pixabay.com/api/docs/
# Sign up → https://pixabay.com/api/docs/ → copy your API key
PIXABAY_API_KEY=your_pixabay_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Other env vars (add yours here as the project grows)
# ─────────────────────────────────────────────────────────────────────────────
# Required for production launch
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEWSLETTER_PROVIDER_API_KEY=re_xxxxxxxxxxxxxxxxx
NEWSLETTER_AUDIENCE_ID=xxxxxxxxxxxxxxxx

# Affiliate query params (set your real IDs per network)
# Keep as raw query strings, e.g. "partner_id=12345&utm_source=exploreswitzerland"
NEXT_PUBLIC_AFFILIATE_GETYOURGUIDE_PARAMS=partner_id=XXXXXXX&utm_medium=online_publisher&utm_source=exploreswitzerland
NEXT_PUBLIC_AFFILIATE_VIATOR_PARAMS=pid=P00XXXXX&mcid=42383&medium=link
NEXT_PUBLIC_AFFILIATE_BOOKING_PARAMS=aid=XXXXXXX&label=exploreswitzerland
NEXT_PUBLIC_AFFILIATE_KLOOK_PARAMS=aid=XXXXX&aff_platform=online_publisher
NEXT_PUBLIC_AFFILIATE_OMIO_PARAMS=partner_id=exploreswitzerland
NEXT_PUBLIC_AFFILIATE_SWISSACTIVITIES_PARAMS=tap_a=XXXXX&utm_source=exploreswitzerland
NEXT_PUBLIC_AFFILIATE_RENTALCARS_PARAMS=affiliateCode=exploreswitzerland
NEXT_PUBLIC_AFFILIATE_SWISSPASS_PARAMS=partner_id=exploreswitzerland

# Optional
# NEXT_PUBLIC_MAPBOX_TOKEN=
