# ─────────────────────────────────────────────────────────────────────────────
# Activity image sources for `npm run fetch-images`
# Copy this file to .env.local and fill in your keys.
# All sources are optional — Wikipedia works without any key.
# ─────────────────────────────────────────────────────────────────────────────

# Unsplash — best quality photos, free, https://unsplash.com/developers
# Sign up → New Application → copy "Access Key"
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels — excellent variety, free, https://www.pexels.com/api/
# Sign up → My Profile → API → copy key
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay — huge library, free, https://pixabay.com/api/docs/
# Sign up → https://pixabay.com/api/docs/ → copy your API key
PIXABAY_API_KEY=your_pixabay_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Phase 1 MVP feature flags
# Routes stay in the codebase but return 404 until flipped to "on".
# Default is OFF (unset = hidden). Turn individual features on in Phase 2.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_PLANNER=off
NEXT_PUBLIC_FEATURE_BUDGET=off
NEXT_PUBLIC_FEATURE_SURPRISE=off
NEXT_PUBLIC_FEATURE_ITINERARIES=off
NEXT_PUBLIC_FEATURE_TRAVEL_PASSES=off
NEXT_PUBLIC_FEATURE_MAP=off
NEXT_PUBLIC_FEATURE_GUIDES=off
NEXT_PUBLIC_FEATURE_PARTNERS=off
NEXT_PUBLIC_FEATURE_DEALS=off
NEXT_PUBLIC_FEATURE_REGIONS=off
NEXT_PUBLIC_FEATURE_PLAN=off

# ─────────────────────────────────────────────────────────────────────────────
# Other env vars (add yours here as the project grows)
# ─────────────────────────────────────────────────────────────────────────────
# Required for production launch
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEWSLETTER_PROVIDER_API_KEY=re_xxxxxxxxxxxxxxxxx
NEWSLETTER_AUDIENCE_ID=xxxxxxxxxxxxxxxx

# Affiliate query params — one var per network. Set the REAL value once the
# program approves you; leave the XXXXXXX placeholder until then.
# `npm run check:revenue` reports which networks are still placeholders.
# Keep as raw query strings, e.g. "partner_id=12345&utm_source=realswitzerland"
# NOTE: in production an UNSET var means no tracking params are appended for
# that network (see trackingFromEnv in src/data/affiliate-partners.ts) — so a
# placeholder here is effectively "off", not "broken".
NEXT_PUBLIC_AFFILIATE_GETYOURGUIDE_PARAMS=partner_id=XXXXXXX&utm_medium=online_publisher&utm_source=realswitzerland
NEXT_PUBLIC_AFFILIATE_VIATOR_PARAMS=pid=P00XXXXX&mcid=42383&medium=link
NEXT_PUBLIC_AFFILIATE_BOOKING_PARAMS=aid=XXXXXXX&label=realswitzerland
NEXT_PUBLIC_AFFILIATE_KLOOK_PARAMS=aid=XXXXX&aff_platform=online_publisher
NEXT_PUBLIC_AFFILIATE_TRAVELPAYOUTS_PARAMS=marker=XXXXXX
NEXT_PUBLIC_AFFILIATE_OMIO_PARAMS=partner_id=XXXXXXX
# SwissActivities is already approved — ref=odbhodn is the live affiliate ref
# (also embedded in scraped booking URLs). Only override if it changes.
NEXT_PUBLIC_AFFILIATE_SWISSACTIVITIES_PARAMS=ref=odbhodn
NEXT_PUBLIC_AFFILIATE_RENTALCARS_PARAMS=affiliateCode=XXXXXXX
NEXT_PUBLIC_AFFILIATE_SWISSPASS_PARAMS=partner_id=XXXXXXX
NEXT_PUBLIC_AFFILIATE_MUSEMENT_PARAMS=utm_source=realswitzerland&utm_medium=affiliate&utm_campaign=XXXXXXX
NEXT_PUBLIC_AFFILIATE_CIVITATIS_PARAMS=aid=XXXXXXX&utm_source=realswitzerland

# Optional
# NEXT_PUBLIC_MAPBOX_TOKEN=
